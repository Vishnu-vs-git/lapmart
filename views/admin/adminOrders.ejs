<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LapMart - Order Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-800 text-white">
<div class="flex h-screen">
  <%- include('../partials/adminSidebar') %>

  <div class="flex-1 p-8">
    <%- include('../partials/adminLoginIcon') %>

    <div class="px-6 py-3 bg-green-700 rounded-2xl mb-4">
      <h1 class="text-2xl font-bold">Order Management</h1>
    </div>

    <div class="bg-gray-800 shadow-md rounded">
      <table class="w-full table-auto">
        <thead class="bg-white text-black uppercase text-sm">
          <tr>
            <th class="py-3 px-6 text-left">Order ID</th>
            <th class="py-3 px-6 text-left">Customer</th>
            <th class="py-3 px-6 text-left">Items & Status</th>
            <th class="py-3 px-6 text-center">Actions</th>
          </tr>
        </thead>

        <tbody class="bg-black text-sm">
        <% orders.forEach(order => { %>
          <tr class="border-b border-gray-700">

            <!-- Order ID -->
            <td class="py-3 px-6">
              <%= order.orderId %>
            </td>

            <!-- Customer -->
            <td class="py-3 px-6">
              <%= order.userId?.userName ?? "N/A" %>
            </td>

            <!-- Items -->
            <td class="py-3 px-6">
              <ul>
              <% order.items.forEach(item => { 
                let statusColor = 'bg-gray-500 text-gray-800';
                switch (item.itemOrderStatus) {
                  case 'Pending': statusColor = 'bg-yellow-300 text-gray-800'; break;
                  case 'Shipped': statusColor = 'bg-green-300 text-gray-800'; break;
                  case 'Delivered': statusColor = 'bg-green-500 text-white'; break;
                  case 'Cancelled': statusColor = 'bg-red-300 text-gray-800'; break;
                  case 'return requested': statusColor = 'bg-yellow-400 text-gray-800'; break;
                  case 'returned': statusColor = 'bg-green-500 text-white'; break;
                }
              %>

                <li class="flex justify-between items-center mb-2">

                  <!-- Product -->
                  <span class="text-xs">
                    <%= item.productId?.name ?? "Product Deleted" %>
                  </span>

                  <div class="flex items-center space-x-2">

                    <!-- Status Badge -->
                    <span class="py-1 px-2 rounded-full text-xs <%= statusColor %>">
                      <%= item.itemOrderStatus %>
                    </span>

                    <% if (item.itemOrderStatus === 'return requested') { %>
                      <!-- Return Action -->
                      <button
                        data-order-id="<%= order._id %>"
                        data-product-name="<%= item.productId ? item.productId.name : '' %>"
                        data-reason="<%= item.returnReason || '' %>"
                        data-product-id="<%= item.productId ? item.productId._id : '' %>"
                        data-user-id="<%= order.userId ? order.userId._id : '' %>"
                        onclick="openReturnModal(this.dataset.orderId, this.dataset.productName, this.dataset.reason, this.dataset.productId, this.dataset.userId)"
                        class="bg-yellow-500 text-black px-2 py-1 rounded text-xs">
                        Action on Return
                      </button>

                    <% } else { %>
                      <!-- Status Change -->
                      <form action="/admin/changeOrderstatus" method="POST" class="flex space-x-2">
                        <input type="hidden" name="orderId" value="<%= order._id %>">
                        <input type="hidden" name="productId" value="<%= item.productId?._id ?? "" %>">
                        <input type="hidden" name="userId" value="<%= order.userId?._id ?? "" %>">

                        <% if (item.itemOrderStatus !== 'returned') { %>
                          <select name="newStatus" class="bg-gray-700 text-gray-300 rounded p-1">
                            <option value="Pending">Pending</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                          </select>

                          <button type="submit"
                            class="bg-blue-500 px-2 py-1 rounded text-xs">
                            Change
                          </button>
                        <% } %>
                      </form>
                    <% } %>

                  </div>
                </li>
              <% }) %>
              </ul>
            </td>

            <!-- Actions -->
            <td class="py-3 px-6 text-center">
              <form action="/admin/orderdetails" method="POST">
                <input type="hidden" name="orderId" value="<%= order.orderId %>">
                <button class="bg-gray-600 px-3 py-1 rounded text-xs">
                  View Details
                </button>
              </form>
            </td>

          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="flex justify-between mt-4">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>" class="bg-blue-500 px-3 py-1 rounded">Prev</a>
      <% } %>

      <div class="flex space-x-2">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>"
             class="px-2 py-1 rounded <%= i === currentPage ? 'bg-blue-500' : 'bg-gray-700' %>">
            <%= i %>
          </a>
        <% } %>
      </div>

      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %>" class="bg-blue-500 px-3 py-1 rounded">Next</a>
      <% } %>
    </div>

  </div>
</div>

<!-- Return Modal -->
<div id="returnModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center">
  <div class="bg-white p-6 rounded w-96 text-black relative">
    <button onclick="closeReturnModal()" class="absolute top-2 right-2">
      <span class="material-icons">close</span>
    </button>

    <h2 class="text-xl font-bold mb-4">Return Request</h2>

    <p><b>Order:</b> <span id="modalOrderId"></span></p>
    <p class="mb-4"><b>Reason:</b> <span id="modalReturnReason"></span></p>

    <div class="flex justify-between">
      <form action="/admin/acceptReturn" method="POST">
        <input type="hidden" name="orderId" id="acceptOrderId">
        <input type="hidden" name="productId" id="acceptProductId">
        <input type="hidden" name="userId" id="acceptUserId">
        <button class="bg-green-600 text-white px-4 py-2 rounded">Accept</button>
      </form>

      <form action="/admin/rejectReturn" method="POST">
        <input type="hidden" name="orderId" id="rejectOrderId">
        <input type="hidden" name="productId" id="rejectProductId">
        <input type="hidden" name="userId" id="rejectUserId">
        <button class="bg-red-600 text-white px-4 py-2 rounded">Reject</button>
      </form>
    </div>
  </div>
</div>

<script>
function openReturnModal(orderId, productName, reason, productId, userId) {
  document.getElementById('modalOrderId').innerText = orderId;
  document.getElementById('modalReturnReason').innerText = reason;
  document.getElementById('acceptOrderId').value = orderId;
  document.getElementById('acceptProductId').value = productId;
  document.getElementById('acceptUserId').value = userId;
  document.getElementById('rejectOrderId').value = orderId;
  document.getElementById('rejectProductId').value = productId;
  document.getElementById('rejectUserId').value = userId;
  document.getElementById('returnModal').classList.remove('hidden');
}

function closeReturnModal() {
  document.getElementById('returnModal').classList.add('hidden');
}
</script>
</body>
</html>
