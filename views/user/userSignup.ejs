<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Signup</title>

  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

  <style>
    .error-text {
      color: #f87171;
      font-size: 0.875rem;
      margin-top: 4px;
    }
    .input-error {
      border-color: #f87171 !important;
    }
  </style>
</head>

<body class="flex items-center justify-center min-h-screen bg-black">

  <div class="bg-[#2E073F] p-8 rounded shadow-md w-full sm:w-3/4 md:w-2/3 lg:w-1/3">

    <h2 class="text-2xl font-bold mb-6 text-center text-white">Sign Up</h2>

    <!-- Server-side error -->
    <% if (message) { %>
      <div class="mb-4 text-red-400 text-sm text-center">
        <%= message %>
      </div>
    <% } %>

    <form action="/user/signup" method="POST" onsubmit="validateForm(event)" class="space-y-4">

      <!-- Username -->
      <div>
        <label class="block text-sm font-medium text-gray-200">Username</label>
        <input
          type="text"
          id="username"
          name="userName"
          class="mt-1 block w-full p-2 border bg-gray-700 text-white rounded-md focus:outline-none"
        />
        <p id="usernameError" class="error-text"></p>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-200">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="mt-1 block w-full p-2 border bg-gray-700 text-white rounded-md focus:outline-none"
        />
        <p id="emailError" class="error-text"></p>
      </div>

      <!-- Phone -->
      <div>
        <label class="block text-sm font-medium text-gray-200">Phone</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          class="mt-1 block w-full p-2 border bg-gray-700 text-white rounded-md focus:outline-none"
        />
        <p id="phoneError" class="error-text"></p>
      </div>

      <!-- Password -->
      <div>
        <label class="block text-sm font-medium text-gray-200">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="mt-1 block w-full p-2 border bg-gray-700 text-white rounded-md focus:outline-none"
        />
        <p id="passwordError" class="error-text"></p>
      </div>

      <!-- Confirm Password -->
      <div>
        <label class="block text-sm font-medium text-gray-200">Confirm Password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          class="mt-1 block w-full p-2 border bg-gray-700 text-white rounded-md focus:outline-none"
        />
        <p id="confirmPasswordError" class="error-text"></p>
      </div>

      <!-- Submit -->
      <button type="submit" class="w-full bg-purple-800 text-white p-2 rounded hover:bg-purple-900">
        Sign Up
      </button>
    </form>

    <!-- Google Signup -->
    <div class="mt-6 text-center">
      <p class="text-sm text-gray-100">Or sign up with</p>
      <a href="/auth/google"
        class="flex items-center justify-center bg-white text-gray-700 py-2 px-4 rounded shadow hover:bg-gray-100 mt-2">
        <img src="../download.jpeg" alt="Google" class="w-6 h-6 mr-2">
        <span>Sign up with Google</span>
      </a>
    </div>

    <!-- Login -->
    <p class="mt-4 text-center text-sm text-gray-100">
      Already have an account?
      <a href="/login" class="text-purple-300 hover:underline">Login here</a>
    </p>

  </div>

  <!-- VALIDATION SCRIPT -->
  <script>
    function validateForm(event) {
      event.preventDefault();

      // Clear previous errors
      document.querySelectorAll('.error-text').forEach(e => e.textContent = '');
      document.querySelectorAll('input').forEach(i => i.classList.remove('input-error'));

      let isValid = true;

      const userName = document.getElementById('username');
      const email = document.getElementById('email');
      const phone = document.getElementById('phone');
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');

      // Username
      if (!userName.value.trim()) {
        showError(userName, 'usernameError', 'Username cannot be empty');
        isValid = false;
      }

      // Email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email.value)) {
        showError(email, 'emailError', 'Please enter a valid email address');
        isValid = false;
      }

      // Phone
      const phoneRegex = /^\d{10}$/;
      if (!phoneRegex.test(phone.value)) {
        showError(phone, 'phoneError', 'Phone number must be exactly 10 digits');
        isValid = false;
      }

      // Password
      const passwordRegex =
        /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/;

      if (!passwordRegex.test(password.value)) {
        showError(
          password,
          'passwordError',
          'Password must be at least 8 characters and include uppercase, lowercase, number, and special character'
        );
        isValid = false;
      }

      // Confirm password
      if (password.value !== confirmPassword.value) {
        showError(confirmPassword, 'confirmPasswordError', 'Passwords do not match');
        isValid = false;
      }

      if (isValid) {
        document.querySelector('form').submit();
      }
    }

    function showError(input, errorId, message) {
      document.getElementById(errorId).textContent = message;
      input.classList.add('input-error');
    }
  </script>

</body>
</html>
